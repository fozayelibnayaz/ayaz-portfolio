# Required only for the hidden Google Drive CV backend on Vercel/Netlify.
# Enable Google Drive API in Google Cloud, create an API key, then set it in your hosting dashboard.
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key

# Optional. Already defaults to the current CV folder ID in server/google-drive-cv.js.
GOOGLE_DRIVE_FOLDER_ID=1VCnTDzoYmmCQ5nMUaIggYnOIyPfJ2h1R
